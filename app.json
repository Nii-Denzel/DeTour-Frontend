{
  "expo": {
    "name": "DeTour",
    "slug": "DeTour",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/detourIcon.jpg",
    "scheme": "detour",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "androidNavigationBar": {
        "visible": "true",
        "translucent": true
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/detourIcon.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/landingScreen.jpg"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DeTour needs your location to show nearby attractions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
